{
  "default_decision": "block",
  "audit_arguments": "hash",
  "budget": {
    "max_calls": 10,
    "max_calls_per_tool": 3,
    "max_identical_calls": 1,
    "max_cost_usd": "0.50"
  },
  "rules": [
    {
      "tool": "database.query",
      "decision": "allow",
      "reason": "read-only database queries are allowed"
    },
    {
      "tool": "email.*",
      "arguments": {
        "to": "*@mycompany.com"
      },
      "decision": "allow",
      "reason": "company email recipients are pre-approved"
    },
    {
      "tool": "email.*",
      "decision": "require_approval",
      "reason": "outbound email requires a human decision"
    },
    {
      "tool": "quotation.create",
      "decision": "require_approval",
      "reason": "creating a customer quotation has external side effects"
    },
    {
      "tool": "filesystem.read",
      "decision": "allow",
      "reason": "read-only file access is allowed"
    },
    {
      "tool": "read_text_file",
      "decision": "allow",
      "reason": "reference MCP server reads are allowed"
    },
    {
      "tool": "search.web",
      "decision": "allow",
      "reason": "web search is allowed within runtime budgets"
    },
    {
      "tool": "shell.run",
      "decision": "allow",
      "reason": "demo shell calls are constrained by repetition budgets"
    },
    {
      "tool": "model.generate",
      "decision": "allow",
      "reason": "backend retries are constrained by repetition budgets"
    },
    {
      "tool": "agent.delegate",
      "decision": "allow",
      "reason": "delegation is constrained by repetition budgets"
    },
    {
      "tool": "human.input",
      "decision": "allow",
      "reason": "repeated human-input requests are constrained by repetition budgets"
    },
    {
      "tool": "filesystem.delete",
      "decision": "require_approval",
      "reason": "file deletion is irreversible"
    },
    {
      "tool": "filesystem.write",
      "decision": "require_approval",
      "reason": "file overwrite requires review"
    }
  ]
}
