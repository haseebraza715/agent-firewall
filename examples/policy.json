{
  "default_decision": "block",
  "audit_arguments": "hash",
  "budget": {
    "max_calls": 10,
    "max_calls_per_tool": 3,
    "max_identical_calls": 2,
    "max_cost_usd": "0.50"
  },
  "rules": [
    {
      "tool": "database.query",
      "decision": "allow",
      "reason": "read-only database queries are allowed"
    },
    {
      "tool": "email.*",
      "arguments": {
        "to": "*@mycompany.com"
      },
      "decision": "allow",
      "reason": "company email recipients are pre-approved"
    },
    {
      "tool": "email.*",
      "decision": "require_approval",
      "reason": "outbound email requires a human decision"
    },
    {
      "tool": "quotation.create",
      "decision": "require_approval",
      "reason": "creating a customer quotation has external side effects"
    },
    {
      "tool": "filesystem.read",
      "decision": "allow",
      "reason": "read-only file access is allowed"
    }
  ]
}
