Output docs/media/agent-firewall-demo.gif

Set Shell "bash"
Set FontSize 22
Set Width 1200
Set Height 640
Set TypingSpeed 20ms
Set Theme {"name":"Agent Firewall","black":"#10141c","red":"#ff6b6b","green":"#69db7c","yellow":"#ffd43b","blue":"#74c0fc","magenta":"#da77f2","cyan":"#66d9e8","white":"#f8f9fa","brightBlack":"#495057","brightRed":"#ff8787","brightGreen":"#8ce99a","brightYellow":"#ffe066","brightBlue":"#a5d8ff","brightMagenta":"#e599f7","brightCyan":"#99e9f2","brightWhite":"#ffffff","background":"#10141c","foreground":"#f8f9fa","selectionBackground":"#343a40","cursorColor":"#69db7c"}

Type "PYTHONPATH=src python3 examples/demo/run_demo.py"
Sleep 500ms
Enter
Sleep 12s
